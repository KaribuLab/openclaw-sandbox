FROM docker.io/linuxserver/webtop:debian-xfce

# Prereqs del sistema. Sin chromium/at-spi/libxtst (no usamos cua-driver;
# openclaw trae su propio stack browser/canvas vía plugins).
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl git xz-utils ca-certificates \
        build-essential g++ \
        ffmpeg ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Node.js v24 (OpenClaw requiere ≥ 22.19, preferimos 24). Instalado a
# /usr/local para estar en PATH tanto para root como para abc (webtop user).
# NO instalamos en build dentro de /config: webtop hace bind-mount de
# /config en runtime, lo que taparía cualquier cosa escrita en build.
RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then ARCH="x64"; \
    elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi && \
    curl -fsSL https://nodejs.org/dist/v24.10.0/node-v24.10.0-linux-${ARCH}.tar.xz \
      | tar -xJ --strip-components=1 -C /usr/local

# OpenClaw + Playwright CLI (instalación global). Se hace en build (NO en
# /config) para que esté disponible ya en el primer boot.
RUN npm install -g openclaw@latest \
                   @playwright/cli@latest \
    && playwright-cli install --skills || true

# Provisioner desatendido. Vive en /usr/local/bin para estar en PATH.
COPY openclaw-provision.sh /usr/local/bin/openclaw-provision.sh
RUN chmod +x /usr/local/bin/openclaw-provision.sh

# -----------------------------------------------------------------------------
# s6-overlay service definitions (análogo a hermes-sandbox)
# -----------------------------------------------------------------------------

# Oneshot: provisioning desatendido. Corre UNA VEZ en el primer boot y aplica
# provider + secretos desde env vars. Idempotente vía sentinela
# /config/.openclaw/.setup-done. Si ya provisionado, exit 0 inmediato. Si
# falla, exit !=0 y s6 NO marca el servicio como up (el gateway queda
# esperando sentinela — ver svc-openclaw-gateway).
#
# El wrapper (s6-init-openclaw-provision-run) ejecuta el provisioner via
# s6-setuidgid abc. Sin esto, el provisioner corre como root y openclaw
# (que corre como abc en el gateway) no puede escribir en /config/.openclaw/.
COPY s6-init-openclaw-provision-run /etc/s6-overlay/s6-rc.d/init-openclaw-provision/run
RUN chmod +x /etc/s6-overlay/s6-rc.d/init-openclaw-provision/run && \
    printf 'oneshot' > /etc/s6-overlay/s6-rc.d/init-openclaw-provision/type && \
    printf '/etc/s6-overlay/s6-rc.d/init-openclaw-provision/run' \
        > /etc/s6-overlay/s6-rc.d/init-openclaw-provision/up && \
    mkdir -p /etc/s6-overlay/s6-rc.d/init-openclaw-provision/dependencies.d && \
    touch /etc/s6-overlay/s6-rc.d/init-openclaw-provision/dependencies.d/init-services && \
    touch /etc/s6-overlay/s6-rc.d/user/contents.d/init-openclaw-provision

# Longrun: gateway supervisado por s6. Auto-restart en crash, depende del
# provisioner (s6 no lo arranca hasta que init-openclaw-provision retorna).
COPY s6-svc-openclaw-gateway-run /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/run
RUN chmod +x /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/run && \
    printf 'longrun' > /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/type && \
    mkdir -p /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/dependencies.d && \
    touch /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/dependencies.d/init-services && \
    touch /etc/s6-overlay/s6-rc.d/svc-openclaw-gateway/dependencies.d/init-openclaw-provision && \
    touch /etc/s6-overlay/s6-rc.d/user/contents.d/svc-openclaw-gateway