#!/usr/bin/with-contenv bash
# Servicio s6-overlay LONGRUN: corre `openclaw gateway run` en foreground,
# supervisado por s6. Auto-restart en crash, arranca en boot, independiente
# del escritorio XFCE. Análogo a hermes-gateway-run de hermes-sandbox.
#
# s6 dependency ya garantiza que init-openclaw-provision retorna antes de
# arrancar este servicio. El sentinel wait es red de seguridad adicional
# (paranoid-mode): si la sentinela no está, gateway loop-ea hasta que esté.

# Esperar a que el provisioner haya escrito la sentinela.
while [ ! -f /config/.openclaw/.setup-done ]; do
    echo "[openclaw-gateway] esperando sentinela /config/.openclaw/.setup-done (provisioner aun no completa)..."
    sleep 5
done

echo "[openclaw-gateway] setup listo — arrancando gateway"
cd /config
# Política de bind:
#   - Sin OPENCLAW_GATEWAY_TOKEN: --bind loopback (seguro, no expone a LAN).
#     El gateway refuse-a bindear a `auto` (0.0.0.0) sin auth.
#   - Con OPENCLAW_GATEWAY_TOKEN: respeta OPENCLAW_GATEWAY_BIND (default `auto`).
#     El token escrito en openclaw.json autoriza conexiones más allá de loopback.
#     Útil para exponer el gateway al host (port mapping) y a la LAN, ej. para
#     OAuth callbacks de Google.
if [ -n "${OPENCLAW_GATEWAY_TOKEN:-}" ]; then
    BIND_FLAG="--bind ${OPENCLAW_GATEWAY_BIND:-auto}"
    echo "[openclaw-gateway] token presente → bind=${BIND_FLAG#--bind }"
else
    BIND_FLAG="--bind loopback"
    echo "[openclaw-gateway] sin token → bind=loopback (gateway NO acepta conexiones externas)"
fi
#
# Usamos `runuser` por la misma razón que el provisioner wrapper: en rootless
# podman ni `s6-setuidgid` (necesita CAP_SETGID) ni `su` (pide password) son
# viables.
exec runuser -u abc -- env HOME=/config PATH=/usr/local/bin:/usr/bin:/bin \
    /usr/local/bin/openclaw gateway run \
        --allow-unconfigured \
        ${BIND_FLAG} \
        --verbose