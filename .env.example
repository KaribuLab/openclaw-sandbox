# Copia este archivo a .env y ajusta valores. NO se versiona (salvo este ejemplo).
# TODO se pasa al contenedor via env_file (compose.yaml). Agrega o quita
# claves OPENCLAW_* sin tocar compose.yaml.
#
# Convenciones (analogas a HERMES_CFG__ / HERMES_ENV__ de hermes-sandbox):
#   OPENCLAW_AUTH_CHOICE=<provider>          shortcut: corre `openclaw onboard`
#                                            --non-interactive con el provider
#                                            adecuado. Hace TODO el setup.
#                                            Valores: lmstudio|ollama|apiKey|
#                                            openai-api-key|zai-api-key|...
#   OPENCLAW_CFG__<dotted.path>=valor   ->   `openclaw config set <path> valor`
#                                            ("__" = "."). Se aplica DESPUES
#                                            del onboard. Para overrides
#                                            arbitrarios (e.g. agent.model).
#   OPENCLAW_ENV__<NAME>=valor         ->   escribe NAME=valor en
#                                            ~/.openclaw/.env (secretos extra).
#                                            Para tokens que el onboarding
#                                            no cubre (e.g. TELEGRAM_*, etc).

# ---- Webtop (escritorio por navegador) ----
# PUID/PGID: linuxserver convention. 1000 = primer usuario del host.
# TITLE: nombre que aparece en la pestana del navegador.
# CUSTOM_USER: nombre display del escritorio (opcional).
# TZ: zona horaria del contenedor.
TZ=America/Santiago
TITLE=OpenClaw Agent
CUSTOM_USER=patricio
PASSWORD=cambia_esto

# =============================================================================
# PROVIDER DE MODELO  (100% agnostico - elige UNO, descomenta su bloque)
# =============================================================================

# ---- LM Studio (LOCAL, gratis) ---------------------------------------------
# Endpoint debe terminar en /v1. Desde el contenedor, 127.0.0.1 != host: usa la
# IP LAN de la maquina que corre LM Studio (ej. http://192.168.1.18:1234/v1).
OPENCLAW_AUTH_CHOICE=lmstudio
OPENCLAW_CUSTOM_BASE_URL=http://127.0.0.1:1234/v1
OPENCLAW_CUSTOM_MODEL_ID=google/gemma-4-e4b
OPENCLAW_LMSTUDIO_API_KEY=lm-studio                 # LM Studio acepta cualquier valor

# ---- Ollama (LOCAL, gratis) ------------------------------------------------
# OPENCLAW_AUTH_CHOICE=ollama
# OPENCLAW_CUSTOM_BASE_URL=http://127.0.0.1:11434
# OPENCLAW_CUSTOM_MODEL_ID=qwen3.5:27b

# ---- Claude / Anthropic (API key de pago) ----------------------------------
# OPENCLAW_AUTH_CHOICE=apiKey
# OPENCLAW_ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI (API key de pago) ----------------------------------------------
# OPENCLAW_AUTH_CHOICE=openai-api-key
# OPENCLAW_OPENAI_API_KEY=sk-...

# ---- Z.AI (API key de pago) ------------------------------------------------
# OPENCLAW_AUTH_CHOICE=zai-api-key
# OPENCLAW_ZAI_API_KEY=...

# ---- Skip auth (modo dev, sin modelo) -------------------------------------
# OPENCLAW_AUTH_CHOICE=skip

# =============================================================================
# GATEWAY (opcional, defaults razonables) -------------------------------------
# =============================================================================
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_GATEWAY_BIND=loopback
# OPENCLAW_GATEWAY_TOKEN=                          # si vacio, onboard genera uno

# =============================================================================
# OVERRIDES ARBITRARIOS DE openclaw.json --------------------------------------
# =============================================================================
# Cualquier OPENCLAW_CFG__* se traduce a `openclaw config set <path> <valor>`.
# " __ " (doble guion bajo) = "." (punto). Un "_" simple se conserva literal.
#
# OPENCLAW_CFG__agent__model=qwen3.5:27b          ->  agent.model=qwen3.5:27b
# OPENCLAW_CFG__gateway__port=19001               ->  gateway.port=19001

# =============================================================================
# SECRETOS / URLS ADICIONALES (escritos en ~/.openclaw/.env) -------------------
# =============================================================================
# OPENCLAW_ENV__TELEGRAM_BOT_TOKEN=123456:ABC...   # bot de @BotFather
# OPENCLAW_ENV__DISCORD_BOT_TOKEN=...
#
# Si defines TELEGRAM_BOT_TOKEN, el provisioner configura el canal unattended
# (openclaw channels add + allowlist si tambien TELEGRAM_ALLOWED_USERS).