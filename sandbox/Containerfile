FROM debian:bookworm

ARG LOCALE=en_US.UTF-8
ARG TZ=UTC

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=${TZ}
ENV VNC_RESOLUTION=1280x720
ENV VNC_PASSWORD=agent
ENV BASH_ENV /home/agent/.bash_env

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    xfce4 \
    xfce4-goodies \
    dbus \
    dbus-x11 \
    x11-utils \
    x11-xserver-utils \
    xinit \
    supervisor \
    python3 \
    xvfb \
    x11vnc \
    tightvncpasswd \
    locales \
    chrony \
    python3-numpy \
    python3-pil \
    python3-websockify \
    xz-utils && \
    rm -rf /var/lib/apt/lists/*

RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then ARCH="x64"; \
    elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi && \
    curl -fsSL https://nodejs.org/dist/v24.10.0/node-v24.10.0-linux-${ARCH}.tar.xz \
      | tar -xJ --strip-components=1 -C /usr/local && \
    npx playwright install chrome

RUN ln -sf /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo ${TZ} > /etc/timezone

RUN sed -i "/${LOCALE}/s/^# //g" /etc/locale.gen && locale-gen

RUN mkdir -p /opt/novnc/utils /opt/novnc/www

RUN wget -q https://github.com/novnc/noVNC/archive/refs/tags/v1.6.0.tar.gz -O /tmp/novnc.tar.gz && \
    mkdir -p /opt/novnc/www && \
    tar -xzf /tmp/novnc.tar.gz -C /opt/novnc && \
    mv /opt/novnc/noVNC-1.6.0/* /opt/novnc/www/ && \
    rm -rf /tmp/novnc.tar.gz

RUN wget -q https://github.com/novnc/websockify/archive/refs/tags/v0.13.0.tar.gz -O /tmp/ws.tar.gz && \
    mkdir -p /opt/novnc/utils && \
    tar -xzf /tmp/ws.tar.gz -C /opt/novnc/utils/ && \
    mv /opt/novnc/utils/websockify-0.13.0 /opt/novnc/utils/websockify && \
    rm -rf /tmp/ws.tar.gz

COPY novnc-index.html /opt/novnc/www/index.html

COPY supervisord.conf /etc/supervisor/conf.d/supervisord.conf

RUN useradd -m -s /bin/bash agent && \
    echo "agent:agent" | chpasswd && \
    mkdir -p /home/agent/.vnc && \
    echo "${VNC_PASSWORD}" | tightvncpasswd -f > /home/agent/.vnc/passwd && \
    chmod 600 /home/agent/.vnc/passwd && \
    chown -R agent:agent /home/agent

COPY xstartup /home/agent/.vnc/xstartup
RUN chmod +x /home/agent/.vnc/xstartup && \
    chown agent:agent /home/agent/.vnc/xstartup

RUN mkdir -p /home/agent/.config/xfce4 \
    /home/agent/.config/xfce4/xfconf \
    /home/agent/.config/xfce4/panel \
    /home/agent/.config/menus \
    /home/agent/.openclaw \
    /home/agent/.playwright \
    /home/agent/.cache \
    /home/agent/.nvm \
    /home/agent/.npm \
    /home/agent/.config && \
    touch /home/agent/.config/setup.env && \
    echo ". /home/agent/.config/setup.env" >> /home/agent/.bashrc
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

COPY xfce-applications.menu /home/agent/.config/menus/applications.menu
RUN chown -R agent:agent /home/agent

RUN echo "allowed_users=anybody" > /etc/X11/Xwrapper.config && \
    echo "needs_root_rights=yes" >> /etc/X11/Xwrapper.config

RUN rm -f /run/dbus/pid

COPY chrony.conf /etc/chrony/chrony.conf

RUN mkdir -p /var/lib/chrony /run/chrony && \
    chown _chrony:_chrony /var/lib/chrony /run/chrony

RUN mkdir -p /run/dbus /run/user/1000
RUN chown agent:agent /run/user/1000

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]